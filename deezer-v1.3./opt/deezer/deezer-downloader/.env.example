# ── Copier ce fichier en .env et remplir les valeurs ────────────────────────

# OBLIGATOIRE: Clé secrète JWT (générer avec: python3 -c "import secrets; print(secrets.token_hex(64))")
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_RANDOM_KEY_64_CHARS

# Compte admin initial (créé automatiquement si aucun user n'existe)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# CORS: domaines autorisés (séparés par des virgules)
CORS_ORIGINS=https://votre-domaine.com,http://localhost:5173

# Base de données (SQLite par défaut, ou PostgreSQL)
DATABASE_URL=sqlite:///deezer_downloader.db
# DATABASE_URL=postgresql://user:pass@localhost/dbname

# Optionnel: Proxy Deezer
# DEEZER_PROXY=socks5://127.0.0.1:9050
